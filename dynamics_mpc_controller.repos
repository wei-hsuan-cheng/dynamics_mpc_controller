repositories:
    # mujoco simulator
    mujoco_ros2_control:
      type: git
      url: https://github.com/wei-hsuan-cheng/mujoco_ros2_control.git
      version: main
    
    # ros2_controller parameter auto generator
    generate_parameter_library:
      type: git
      url: https://github.com/wei-hsuan-cheng/generate_parameter_library.git
      version: humble

    # ocs2 stack
    ocs2_ros2:
      type: git
      url: https://github.com/wei-hsuan-cheng/ocs2_ros2.git
      version: humble_frame_relation
    ocs2_ros2/submodules/ocs2_robotic_assets:
      type: git
      url: https://github.com/wei-hsuan-cheng/ocs2/ocs2_robotic_assets.git
      version: ros2_x86
    ocs2_ros2/submodules/plane_segmentation_ros2:
      type: git
      url: https://github.com/wei-hsuan-cheng/ocs2/plane_segmentation_ros2.git
      version: main